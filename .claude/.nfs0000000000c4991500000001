{
  "permissions": {
    "allow": [
      "Bash(wc -l /DATA/Backup/MikroDash/src/collectors/*.js)",
      "Bash(grep \"^test\\(\" /DATA/Backup/MikroDash/test/*.test.js)",
      "Skill(update-config)",
      "Bash(sudo -n true)",
      "Bash(docker ps:*)",
      "Bash(chmod +x /DATA/Backup/rebuild_mikrodash.sh)",
      "Bash(/DATA/Backup/rebuild_mikrodash.sh)",
      "Bash(jq:*)",
      "Bash(node --test test/collector-data-transforms.test.js)",
      "Bash(docker exec:*)",
      "Bash(docker cp:*)",
      "Bash(xargs md5sum:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/DATA/Backup/rebuild_mikrodash.sh",
            "timeout": 300,
            "async": true,
            "statusMessage": "Rebuilding MikroDash container..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/DATA/Backup/rebuild_mikrodash.sh",
            "timeout": 300,
            "statusMessage": "Rebuilding MikroDash container..."
          }
        ]
      }
    ]
  }
}
